# ===== 运行环境 =====
ENV=development
APP_VERSION=1.13.0

# ===== 安全 =====
# 生产环境改为实际域名，多个用逗号分隔
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ===== 数据库 =====
DATABASE_URL=sqlite:///./data.db

# ===== JWT 认证 =====
# 使用 python -c "import secrets; print(secrets.token_urlsafe(32))" 生成安全密钥
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ===== DeepSeek API =====
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ===== LLM 调用参数 =====
LLM_MAX_RETRIES=3
LLM_REQUEST_TIMEOUT=90
LLM_CONCURRENT_LIMIT=10
LLM_CONNECTION_POOL_SIZE=20
LLM_CONNECTION_KEEPALIVE=10

# 聊天用短超时 + 少量 token
LLM_CHAT_TIMEOUT=30
LLM_CHAT_MAX_TOKENS=512
# 评分用长超时 + 更多 token
LLM_SCORING_TIMEOUT=120
LLM_SCORING_MAX_TOKENS=2048
